# Ameen eSIM — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local (see .gitignore).

# ── Core ────────────────────────────────────────────────────────────────
DATABASE_URL=                       # Neon Postgres connection string
NEXT_PUBLIC_SITE_URL=http://localhost:3000
OWNER_EMAIL=

# ── eSIM provider switch + creds (only the ACTIVE one needs filling) ──────
# mock (default in dev) | airalo | maya | esimaccess
ESIM_PROVIDER=mock
AIRALO_CLIENT_ID=
AIRALO_CLIENT_SECRET=
MAYA_API_KEY=
ESIMACCESS_ACCESS_CODE=
ESIMACCESS_SECRET_KEY=
# ESIMACCESS_BASE_URL=                # optional; defaults to https://api.esimaccess.com

# ── Payments (Stripe, GBP only) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=
SUPPORT_EMAIL=

# ── Admin auth (Clerk) ────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────
WHATSAPP_NUMBER=                    # e.g. 447XXXXXXXXX
