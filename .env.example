# Ameen eSIM — environment variables
# Copy to .env.local for development. Mirror on Vercel for production.
# The app is local-first: everything below is optional on localhost (mock
# provider, in-memory stores), but required in production as noted.

# --- Core (required in production) ------------------------------------------
# Neon pooled connection string. REQUIRED in production: without it the app
# refuses to store orders (no silent in-memory fallback for paid records).
DATABASE_URL=

# Canonical site origin, no trailing slash. REQUIRED in production: Stripe
# success/cancel URLs are built from it (never from the Host header).
NEXT_PUBLIC_SITE_URL=https://www.ameen-esim.co.uk

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY=
# Verified from-address, e.g. "Ameen eSIM <orders@alwaseelahtravel.co.uk>"
ORDER_EMAIL_FROM=
SUPPORT_EMAIL=
# Receives failure alerts (paid-but-not-provisioned, email send failures).
OWNER_EMAIL=

# --- Admin (/admin) ----------------------------------------------------------
ADMIN_PASSWORD=
# Signs the admin session cookie. Set to a long random string (e.g.
# `openssl rand -hex 32`) so a leaked cookie can't be used to brute-force
# ADMIN_PASSWORD offline. Falls back to ADMIN_PASSWORD if unset.
ADMIN_SESSION_SECRET=

# --- Cron --------------------------------------------------------------------
# Vercel sends `Authorization: Bearer ${CRON_SECRET}` to /api/cron/*.
# The provisioning sweep fails closed without it.
CRON_SECRET=

# --- eSIM provider -----------------------------------------------------------
# mock | esimaccess | maya | airalo
ESIM_PROVIDER=mock

ESIMACCESS_ACCESS_CODE=
ESIMACCESS_SECRET_KEY=
# ESIMACCESS_BASE_URL=https://api.esimaccess.com

MAYA_API_KEY=

AIRALO_CLIENT_ID=
AIRALO_CLIENT_SECRET=
